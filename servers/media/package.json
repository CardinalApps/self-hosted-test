{
  "name": "@cardinalapps/media-server",
  "description": "Self-hosted Cardinal Media Server.",
  "license": "Elastic License 2.0 (ELv2)",
  "version": "0.6.1",
  "author": "Brian <brian@cardinalapps.io> (https://github.com/briiian)",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "dev:pg": "CARDINAL_POSTGRES=true nest start --watch",
    "prebuild": "rimraf dist",
    "build": "nest build",
    "build:bin": "pkg --config ./package.json --out-path ./bin/prod ./dist/main.js",
    "build:bin:dev": "pkg --debug --config ./package.json --out-path ./bin/dev ./dist/main.js",
    "bundle": "pnpm bundle:admin && pnpm bundle:photos && pnpm bundle:music && pnpm bundle:cinema",
    "bundle:admin": "rm -rf ./public/admin && rsync -av --progress ../../apps/admin-web/dist/admin/* ./public/admin && rsync -av --progress ../../apps/admin-web/package.json ./public/admin",
    "bundle:photos": "rm -rf ./public/photos && rsync -av --progress ../../apps/photos-web/dist/photos/* ./public/photos && rsync -av --progress ../../apps/photos-web/package.json ./public/photos",
    "bundle:music": "rm -rf ./public/music && rsync -av --progress ../../apps/music-web/dist/music/* ./public/music && rsync -av --progress ../../apps/music-web/package.json ./public/music",
    "bundle:cinema": "rm -rf ./public/cinema && rsync -av --progress ../../apps/cinema-web/dist/cinema/* ./public/cinema && rsync -av --progress ../../apps/cinema-web/package.json ./public/cinema",
    "start": "nest start",
    "start:pg": "CARDINAL_POSTGRES=true nest start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "PHOTOS_DIR=/home/brian/Pictures MUSIC_DIR=/home/brian/Music node dist/main",
    "start:bin:dev": "DEBUG_PKG=1 PHOTOS_DIR=/home/brian/Pictures ./bin/dev/@cardinalapps/media-server",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=development RELEASE_CHANNEL=development jest --verbose --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "NODE_ENV=development jest --config ./tests/jest.integration.json --runInBand"
  },
  "dependencies": {
    "@cardinalapps/access-control": "workspace:*",
    "@cardinalapps/app-settings": "workspace:*",
    "@cardinalapps/products": "workspace:*",
    "@cardinalapps/topology": "workspace:*",
    "@eslint/js": "^9.21.0",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/graphql": "^12.2.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/platform-ws": "^10.3.10",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.3.10",
    "@types/better-queue": "^3.8.6",
    "@types/lodash": "^4.17.6",
    "bcryptjs": "^3.0.3",
    "better-queue": "^3.8.12",
    "better-sqlite3": "^11.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "date-fns": "^3.1.0",
    "directory-tree": "^3.5.1",
    "exifr": "^7.1.3",
    "ffmpeg-static": "^5.3.0",
    "file-type": "16.5.4",
    "fs-extra": "^11.1.1",
    "glob": "^9.3.1",
    "graphql": "^16.9.0",
    "heic-convert": "^1.2.4",
    "ip": "^1.1.8",
    "jwt-decode": "^3.1.2",
    "lodash": "^4.17.21",
    "ms": "^2.1.3",
    "music-metadata": "^7.14.0",
    "osenv": "^0.1.5",
    "path-scurry": "1.11.1",
    "pg": "^8.12.0",
    "random-word-slugs": "^0.1.7",
    "raw-body": "^2.5.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.2.0",
    "semver": "^7.5.4",
    "sharp": "^0.32.0",
    "typeorm": "^0.3.20",
    "typeorm-naming-strategies": "^4.1.0",
    "ua-parser-js": "^1.0.37",
    "unique-names-generator": "^4.7.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@cardinalapps/eslint-config": "workspace:*",
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.2",
    "@nestjs/testing": "^10.3.10",
    "@types/express": "^4.17.13",
    "@types/jest": "28.1.4",
    "@types/node": "^16.0.0",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^2.0.11",
    "@types/uuid": "^9.0.8",
    "eslint": "^9.20.1",
    "jest": "^29.7.0",
    "pkg": "^5.8.1",
    "rimraf": "5.0.10",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "^29.1.5",
    "ts-loader": "^9.2.3",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "4.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "8.22.0"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "package.json",
      "public/**/*",
      "../../node_modules/swagger-ui-dist/**/*",
      "../../node_modules/music-metadata/**/*",
      "../../node_modules/better-sqlite3/**/*",
      "../../node_modules/sharp/**/*"
    ],
    "targets": [
      "node18-linux-x64"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
