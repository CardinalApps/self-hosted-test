{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../",
  "testRegex": "tests/.*\\.integration\\.ts$",
  "testEnvironment": "node",
  "silent": true,
  "verbose": true,
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "./tsconfig.test.json" }]
  },
  "testTimeout": 60000,
  "detectOpenHandles": true,
  "forceExit": true
}
