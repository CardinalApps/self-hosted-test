diff a/servers/media/openapi.json b/servers/media/openapi.json	(rejected hunks)
@@ -1 +1 @@
-{"openapi":"3.0.0","paths":{"/api":{"get":{"operationId":"AppController_apiHome","summary":"Get information about your API.","description":"Returns information about the API itself.","parameters":[],"responses":{"200":{"description":"Lists all available versions of your API, and all endpoints across all versions of your API.","content":{"application/json":{"schema":{"example":{"versions":{"v1":"/api/v1"},"endpoints":["GET /api/v1/health"]}}}}}},"tags":["General"]}},"/api/v1/health":{"get":{"operationId":"AppController_getHealth","summary":"Know if your Media Server is online.","description":"Responds to health checks. This may also:\n\n1. Include information about pending updates.\n1. Trigger an update check (infrequently).","parameters":[],"responses":{"200":{"description":"Returns the state of the server. If the server responds, then it's online.\n      Responses will always have a 200 status. Possible states are: \n      `normal`,  `not_setup.`","content":{"application/json":{"schema":{"example":{"state":"normal"}}}}}},"tags":["General"]}},"/api/v1/release-channels":{"get":{"operationId":"AppController_getCurrentReleaseChannel","summary":"Get the current release channel.","description":"Get the current release channel.","parameters":[],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"type":"object"}}}}},"tags":["General"]}},"/api/v1/updates":{"get":{"operationId":"AppController_getAvailableUpdates","summary":"Manually check for available updates.","description":"Queries the cloud servers to check if updates are available, and returns\ninformation about them. Does not support the development environment.","parameters":[],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"example":{"updateIsAvailable":true,"daysBehindLatestVersion":42,"latestVersion":"0.0.1","latestVersionReleasedAt":"Thu Jan 04 2024 21:28:00 GMT-0500 (Eastern Standard Time)"}}}}},"503":{"description":"Returns a 503 if the latest version cannot be fetched from the cloud, or if the server is running in development mode."}},"tags":["General"]}},"/api/v1/setup":{"post":{"operationId":"AppController_setup","summary":"Initial setup.","description":"Handles server initialization after the user has been asked the first time\nsetup questions. If the user opted to log into their Cardinal cloud\naccount during setup then a local user will be created and linked with\ntheir cloud account.\n\nAfter the initial setup is complete, this endpoint cannot be used again.","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ServerSetupDto"}}}},"responses":{"201":{"description":"Returns an empty Created response on success."},"403":{"description":"Returns a Forbidden error if initial setup has already been completed."}},"tags":["General"]}},"/api/v1/versions":{"get":{"operationId":"AppController_getAppVersions","summary":"Get versions of things.","description":"Get a list of versions of things in the Media Server. In the `build_tag`,\nthe timestamp is of the build, not the commit.","parameters":[],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"example":{"nodejs":"0.0.0","openssl":"0.0.0","database":"0.0.0","cardinal_home_server":"0.0.0","cardinal_home_server_web_app":"0.0.0","cardinal_music_web_app":"0.0.0","cardinal_photos_web_app":"0.0.0","cardinal_cinema_web_app":"0.0.0","build_tag":"<release_channel>-<commit>-<YYMMDDTHHMMSS>"}}}}}},"security":[{"Local User JWT":[]}],"tags":["General"]}},"/api/v1/reset":{"post":{"operationId":"AppController_reset","summary":"Reset server state.","description":"Handles resetting things.","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ServerResetDto"}}}},"responses":{"201":{"description":"","content":{"application/json":{"schema":{"type":"boolean"}}}}},"tags":["General"]}},"/api/v1/ls":{"get":{"operationId":"AppController_ls","summary":"List the contents of a directory.","description":"Lists the contents of a directory. Only some directories that are owned by\nCardial Media Server can be browsed.","parameters":[{"name":"rootDir","required":true,"in":"query","description":"The directories whose contents can be listed.","schema":{"enum":["music","photos","movies","tv"],"type":"string"}},{"name":"path","required":false,"in":"query","description":"The path of the directory to list within the selected rootDir.","schema":{"type":"string"}},{"name":"removeFileNodes","required":false,"in":"query","description":"Remove file nodes from the list, leaving only directories.","schema":{"default":false,"type":"boolean"}},{"name":"addEmptyNodes","required":false,"in":"query","description":"Adds \"empty nodes\" to the list to designate empty directories.","schema":{"default":true,"type":"boolean"}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["General"]}},"/api/v1/login":{"post":{"operationId":"AuthController_login","summary":"Log into a local account.","description":"Logs the user into a local account.\n\nIf logging into a local offline account, no credentials are required.\n\nIf logging into a local online account, a valid Cardinal SSO token is\nrequired.","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/LoginDetails"}}}},"responses":{"201":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/LoginResponse"}}}},"401":{"description":"Returns an Unauthorized error if there is an issue with the Cardinal token."}},"tags":["Authentication"]}},"/api/v1/settings/{app}":{"get":{"operationId":"SettingsController_getAppSettings","summary":"Get app settings.","description":"Gets all settings for a single app.","parameters":[{"name":"app","required":true,"in":"path","schema":{"enum":["admin","music","photos","cinema"],"type":"string"}}],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/GetAppSettingsResponse"}}}}},"security":[{"Local User JWT":[]}],"tags":["Settings"]}},"/api/v1/settings":{"patch":{"operationId":"SettingsController_upsertSettings","summary":"Save app settings.","description":"Updates one or more settings in the database for a Cardinal app.","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpsertSettings"}}}},"responses":{"200":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpsertSettingsResponse"}}}}},"security":[{"Local User JWT":[]}],"tags":["Settings"]}},"/api/v1/user":{"get":{"operationId":"UserController_getCurrentUser","summary":"Get the currently logged in local user.","description":"Returns information about the currently logged in user. Local online\naccounts must also provide their cloud token.\n\nThis may trigger a refresh of the cached cloud user data.","parameters":[{"name":"CardinalTolkien","in":"header","schema":{"type":"string"}}],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/GetUserResponse"}}}},"401":{"description":"Returns an Unauthorized error if there is an issue with the token."}},"security":[{"Local User JWT":[]}],"tags":["User"]},"post":{"operationId":"UserController_createLocalUser","summary":"Create a new local Media Server user.","description":"Creates a local user. Local users can be one of two types: `offline` or\n`online`.\n\n*`online`* - A local user account with a linked Cardinal account is called an\n`online` user. There can only be 1 online user per Media Server, and\nthat is the server owner.\n\n*`offline`* - A local user account without a linked Cardinal account is\ncalled an `offline` user. The only offline account is the nameless &\npasswordless one that comes included with the Media Server, called \"Offline\nAccount\".","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateUser"}}}},"responses":{"201":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/User"}}}},"405":{"description":"The server will refuse to create more than 1 `online` account and will refuse to create `offline` accounts."}},"security":[{"Local User JWT":[]}],"tags":["User"]}},"/api/v1/user/{id}":{"get":{"operationId":"UserController_getUser","summary":"Get a specific user.","description":"Returns the user for the given local user ID.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"string"}}],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"type":"object"}}}}},"security":[{"Local User JWT":[]}],"tags":["User"]},"patch":{"operationId":"UserController_updateUser","summary":"Update a user.","description":"FIXME this endpoint needs proper RBAC","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdateUserDto"}}}},"responses":{"200":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/User"}}}}},"security":[{"Local User JWT":[]}],"tags":["User"]}},"/api/v1/users":{"get":{"operationId":"UserController_getUsers","summary":"Get all users in this server.","description":"Returns all users in this server.","parameters":[{"name":"roles","required":false,"in":"query","schema":{"type":"boolean"}},{"name":"sort","required":false,"in":"query","schema":{"default":"createdAt","enum":["createdAt"],"type":"string"}},{"name":"take","required":false,"in":"query","schema":{"default":12,"type":"number"}},{"name":"skip","required":false,"in":"query","schema":{"default":0,"type":"number"}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["User"]}},"/api/v1/users/owner":{"get":{"operationId":"UserController_getOwner","summary":"","description":"Returns the server owner, if there is one.","parameters":[],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"type":"object"}}}}},"security":[{"Local User JWT":[]}],"tags":["User"]}},"/api/v1/users/public":{"get":{"operationId":"UserController_getPublicUsers","summary":"Get all users in this server.","description":"Returns a curated list of sanitized user objects meant to be shown on the login screen.","parameters":[],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"type":"array","items":{"type":"object"}}}}}},"tags":["User"]}},"/api/v1/users/active":{"get":{"operationId":"UserController_getActiveUsers","summary":"Get active Media Server users.","description":"Returns all active users for this server.","parameters":[],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/User"}}}}}},"security":[{"Local User JWT":[]}],"tags":["User"]}},"/api/v1/licensing/subscription":{"get":{"operationId":"LicensingController_getCurrentSubscription","summary":"Get the subscription tier.","description":"Get the current Cardinal subcription tier for this server.","parameters":[],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"type":"object"}}}}},"security":[{"Local User JWT":[]}],"tags":["Licensing"]}},"/api/v1/licensing/seats":{"get":{"operationId":"LicensingController_getSeats","summary":"Get information about seat usage.","description":"Returns information about the current number of seats and how many have\nbeen used.","parameters":[],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Licensing"]}},"/api/v1/roles/assignments":{"get":{"operationId":"RBACController_getRoleAssignments","summary":"Get all role assignments.","description":"Returns all role assignments for all users.","parameters":[{"name":"userId","required":true,"in":"query","schema":{"type":"string"}}],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/RoleAssignment"}}}}}},"tags":["Role Assignments"],"security":[{"Local User JWT":[]}]}},"/api/v1/roles/{role}/assignments":{"post":{"operationId":"RBACController_assignRoles","summary":"Assign one or more roles.","description":"Assigns roles by creating a role assignments. If the user already has the\nrole, the existing assignment will silently returned instead of creating a\nnew one.","parameters":[{"name":"role","required":true,"in":"path","schema":{"type":"string"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AssignRolesDto"}}}},"responses":{"201":{"description":"","content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/RoleAssignment"}}}}}},"tags":["Role Assignments"],"security":[{"Local User JWT":[]}]},"delete":{"operationId":"RBACController_revokeRoles","summary":"Revoke roles.","description":"Revokes roles by deleting the assignment.","parameters":[{"name":"userIds","required":true,"in":"query","schema":{"default":[],"type":"array","items":{"type":"string"}}},{"name":"role","required":true,"in":"path","schema":{"type":"string"}}],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/RoleAssignment"}}}}}},"tags":["Role Assignments"],"security":[{"Local User JWT":[]}]}},"/api/v1/events/subscribe":{"get":{"operationId":"EventController_sse","summary":"Subscribe to real time events.","description":"Subscribe to events. An `EventSource` can be used to listen to events (the\nSwagger test page won't work).\n\nEach client connection is unique to that client app, and clients will only\nreceive the events that are meant for them.\n\nThe JWT must be sent in the `authorization` query param instead of the\nheader.","parameters":[{"name":"authorization","required":true,"in":"query","schema":{"type":"string"}}],"responses":{"200":{"description":""}},"tags":["Events"]}},"/api/v1/index/state":{"get":{"operationId":"IndexingController_getState","summary":"Get the current state of the indexing service.","description":"Returns the real time state of the indexing service. Use this endpoint for\none-time checks. For instant updates when the state changes, use the\n`/events/subscribe` endpoint instead.","parameters":[],"responses":{"200":{"description":"The returned object will contain the state of the indexing service. \n      Possible states are `idle` `indexing` `paused`.","content":{"application/json":{"schema":{"example":{"state":"idle"}}}}}},"security":[{"Local User JWT":[]}],"tags":["Indexing"]},"patch":{"operationId":"IndexingController_changeState","summary":"Control the current indexing run.","description":"Update the state of the currently running indexing operation. This endpoint\nis dedicated to controlling the indexing service from the frontend, and\ncannot update completed runs.\n\nThis endpoint is designed to accept actions. Instead of sending the desired\nstate, send an action and let the indexing service handle the change\ninternally. So, you send \"stop\", and internally the service will terminate\nthe run and change the state to `idle`.\n\nAccepted actions are:\n\n - `pause` - Pauses the run after the current file has completed indexing.\n   The internal state will change to `paused`.\n - `resume` - Resumes a run and continues with the next file. Triggering\n   resume on a run that isn't paused will have no effect. The internal\n   state will change to `indexing`.\n - `stop` - Stops a run after the current file has completed indexing. The\n   internal state will change to `idle`, and a new run can be started.","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/StateChangeActionDto"}}}},"responses":{"200":{"description":""},"409":{"description":"Returns a 409 if the action is not compatible \n    with the current indexing state. For example, sending `stop` \n    while the server is `idle`."}},"security":[{"Local User JWT":[]}],"tags":["Indexing"]}},"/api/v1/index/directories":{"get":{"operationId":"IndexingController_getDirectories","summary":"Get your media directories.","description":"Get the user's media directories. Directories are set via environment\nvariables.","parameters":[],"responses":{"200":{"description":"Returns an array of all media directories that the user told Cardinal Media Server to use.","content":{"application/json":{"schema":{"example":{"music":"/path/to/my/music","photos":"/path/to/my/photos","movies":"/path/to/my/movies","tv":"/path/to/my/tv"}}}}}},"security":[{"Local User JWT":[]}],"tags":["Indexing"]}},"/api/v1/index/counts":{"get":{"operationId":"IndexingController_getFileCounts","summary":"Count your files.","description":"Get the home server's file counts.","parameters":[],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"example":{"musicFiles":10,"photoFiles":12,"movieFiles":20,"tvFiles":24}}}}}},"security":[{"Local User JWT":[]}],"tags":["Indexing"]}},"/api/v1/index/runs":{"get":{"operationId":"IndexingController_getRuns","summary":"Get your previous indexing runs.","description":"Get all of the the user's previous indexing runs.","parameters":[{"name":"take","required":false,"in":"query","schema":{"default":12,"type":"number"}},{"name":"skip","required":false,"in":"query","schema":{"default":0,"type":"number"}}],"responses":{"200":{"description":"Returns an array where the first item is an array of query results, and the second item is the total number of runs.","content":{"application/json":{"schema":{"example":[[{"runId":"7b74fae5-c377-4352-983d-0981e9b9fbec"}],24]}}}}},"security":[{"Local User JWT":[]}],"tags":["Indexing"]}},"/api/v1/index/run":{"post":{"operationId":"IndexingController_startManualIndexingRun","summary":"Start an indexing run.","description":"Creates a new Run in the database and starts the indexing operation for\nthat Run. This endpoint can only be used if there is not currently a run\nrunning.\n\nThe indexing operation will continue to run on the server after this\nendpoint has returned a response.","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateRunDto"}}}},"responses":{"201":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Run"}}}}},"security":[{"Local User JWT":[]}],"tags":["Indexing"]}},"/api/v1/index/file":{"get":{"operationId":"IndexingController_getFile","summary":"Get files from your index.","description":"Get one or more files from your index. Depending on the filetype, addtional\ninformation will be returned about the entities that were extracted from\nthe file.","parameters":[{"name":"ids","required":false,"in":"query","schema":{"default":[],"type":"array","items":{"type":"string"}}},{"name":"library","required":false,"in":"query","schema":{"type":"string"}}],"responses":{"200":{"description":"Returns the file object with optional entities.","content":{"application/json":{"schema":{}}}}},"security":[{"Local User JWT":[]}],"tags":["Indexing"]}},"/api/v1/index/files":{"delete":{"operationId":"IndexingController_deleteFiles","summary":"Deindex one or more of your files.","description":"Deindexes one or more files. To \"deindex\" means to delete the file entity\nand all of its derived entities like songs and episodes, and all of their\nderived entities like metadata and thumbnails.\n\nDeindexing however does not delete cached static resources on the disk like\nthe thumbnail files that the server generates when initially indexing\nthings. Those now stale assets will eventually be deleted by a cleanup cron\njob.\n\nIf a wildcard (`*`) is given as the sole item in the array, all files will\nbe deindexed. The wildcard method only supports hard deleting, so you must\nalso set `hardDelete` to true to activate it. Only a `true` boolean will be\nreturned when the wildcard operation is done.\n\nBy default, this deindexing is a soft delete. To perform a hard delete, set\nthe `hardDelete` param to true.","parameters":[{"name":"ids","required":true,"in":"query","schema":{"default":[],"type":"array","items":{"type":"string"}}},{"name":"hardDelete","required":false,"in":"query","schema":{"default":false,"type":"boolean"}}],"responses":{"200":{"description":"Returns an object of file IDs and booleans, indicating whether each file was successfully deindexed.","content":{"application/json":{"schema":{"example":{"7b74fae5-c377-4352-983d-0981e9b9fbec":true}}}}}},"security":[{"Local User JWT":[]}],"tags":["Indexing"]}},"/api/v1/music/track/{id}":{"get":{"operationId":"MusicTrackController_getMusicTrack","summary":"Get a single music track.","description":"Get a music track.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"string"}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Music"]}},"/api/v1/music/tracks":{"get":{"operationId":"MusicTrackController_getTracks","summary":"Query music tracks.","description":"Get the users tracks.","parameters":[{"name":"metadata","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"release","required":false,"in":"query","schema":{"default":true,"type":"boolean"}},{"name":"artists","required":false,"in":"query","schema":{"default":true,"type":"boolean"}},{"name":"sort","required":false,"in":"query","schema":{"default":"trackNumber","enum":["createdAt","updatedAt","title","trackNumber","discNumber","duration","bitrate"],"type":"string"}},{"name":"take","required":false,"in":"query","schema":{"default":12,"type":"number"}},{"name":"skip","required":false,"in":"query","schema":{"default":0,"type":"number"}}],"responses":{"200":{"description":"Returns an array where the first item is the paginated set of results, and the second item is the total number of results for this query."}},"security":[{"Local User JWT":[]}],"tags":["Music"]}},"/api/v1/music/stream/{id}":{"get":{"operationId":"MusicTrackController_streamMusicTrack","summary":"Stream a music track.","description":"Stream a music track.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"string"}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Music"]}},"/api/v1/music/release/{id}":{"get":{"operationId":"MusicReleaseController_getMusicArtist","summary":"Get a single music release.","description":"Get a music release.","parameters":[{"name":"tracks","required":false,"in":"query","schema":{"type":"boolean"}},{"name":"genres","required":false,"in":"query","schema":{"type":"boolean"}},{"name":"artists","required":false,"in":"query","schema":{"type":"boolean"}},{"name":"thumbnails","required":false,"in":"query","schema":{"type":"boolean"}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Music"]}},"/api/v1/music/releases":{"get":{"operationId":"MusicReleaseController_getMusicReleases","summary":"Query music releases.","description":"Get the users music releases.","parameters":[{"name":"genres","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"tracks","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"artists","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"thumbnails","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"metadata","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"sort","required":false,"in":"query","schema":{"default":"createdAt","enum":["createdAt","updatedAt","title"],"type":"string"}},{"name":"take","required":false,"in":"query","schema":{"default":12,"type":"number"}},{"name":"skip","required":false,"in":"query","schema":{"default":0,"type":"number"}}],"responses":{"200":{"description":"Returns an array where the first item is the paginated set of results, and the second item is the total number of results for this query."}},"security":[{"Local User JWT":[]}],"tags":["Music"]}},"/api/v1/music/releases/{id}/cover":{"get":{"operationId":"MusicReleaseController_getReleaseCoverBlob","summary":"Get the cover image of a release.","description":"Returns the blob data of a release cover. Supports numeric row ID and musicReleaseId col.","parameters":[],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Music"]}},"/api/v1/music/artist/{id}":{"get":{"operationId":"MusicArtistController_getMusicArtist","summary":"Get a single music artist.","description":"Get a music artist.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"string"}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Music"]}},"/api/v1/music/artists":{"get":{"operationId":"MusicArtistController_getMusicArtists","summary":"Query music artists.","description":"Get the users music artists.","parameters":[{"name":"tracks","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"metadata","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"releases","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"orderBy","required":false,"in":"query","schema":{"default":"createdAt","enum":["createdAt","updatedAt","name","sortName"],"type":"string"}},{"name":"take","required":false,"in":"query","schema":{"default":12,"type":"number"}},{"name":"skip","required":false,"in":"query","schema":{"default":0,"type":"number"}}],"responses":{"200":{"description":"Returns an array where the first item is the paginated set of results, and the second item is the total number of results for this query."}},"security":[{"Local User JWT":[]}],"tags":["Music"]}},"/api/v1/music/genre/{id}":{"get":{"operationId":"MusicGenreController_getMusicArtist","summary":"Get a single music genre.","description":"Get a music genre.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"number"}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Music"]}},"/api/v1/photos":{"get":{"operationId":"PhotoController_getPhotos","summary":"Get your photos.","description":"Get the users photos.","parameters":[{"name":"metadata","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"thumbnails","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"photoAlbumEntries","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"orderBy","required":false,"in":"query","schema":{"default":"takenAt","enum":["createdAt","takenAt","modifiedAt","width","height","deviceMake","deviceModel","gpsLat","gpsLng","gpsAltitude"],"type":"string"}},{"name":"take","required":false,"in":"query","schema":{"default":12,"type":"number"}},{"name":"skip","required":false,"in":"query","schema":{"default":0,"type":"number"}}],"responses":{"200":{"description":"Returns an array where the first item is an array of query results, and the second item is the total number of photos.","content":{"application/json":{"schema":{"example":[[{"photoId":"7b74fae5-c377-4352-983d-0981e9b9fbec"},{"photoId":"7b74fae5-c377-4352-983d-0981e9b9fbec"},{"photoId":"7b74fae5-c377-4352-983d-0981e9b9fbec"},{"photoId":"7b74fae5-c377-4352-983d-0981e9b9fbec"}],24]}}}}},"security":[{"Local User JWT":[]}],"tags":["Photos"]}},"/api/v1/photos/count":{"get":{"operationId":"PhotoController_countPhotos","summary":"Count your photo entities.","description":"Returns the number of photo entities in the database (not the number of\nfiles on the disk).","parameters":[],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"example":24}}}}},"security":[{"Local User JWT":[]}],"tags":["Photos"]}},"/api/v1/photo/{id}":{"get":{"operationId":"PhotoController_getPhoto","summary":"Get data about a photo.","description":"Get the users photos.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"number"}},{"name":"file","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"metadata","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"thumbnails","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"photoAlbumEntries","required":false,"in":"query","schema":{"default":false,"type":"boolean"}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Photos"]},"patch":{"operationId":"PhotoController_updatePhoto","summary":"Update a photo.","description":"Updates a photo.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"string"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdatePhotoBodyDto"}}}},"responses":{"200":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Photo"}}}}},"security":[{"Local User JWT":[]}],"tags":["Photos"]}},"/api/v1/photo/{id}/blob":{"get":{"operationId":"PhotoController_getPhotoBlob","summary":"Get a photo.","description":"Returns the blob data of one of the photos in the photo library.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"number"}},{"name":"autoConvert","required":false,"in":"query","description":"When auto convert is enabled, the server will return the best image format\nfor the client.\n\nCases:\n\n1. HEIC/HEIF images will be converted to JPEG for clients that are not\n   macOS and not Windows 11.","schema":{"default":true,"type":"boolean"}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Photos"]}},"/api/v1/photo/{id}/thumbnail":{"get":{"operationId":"PhotoController_getReleaseCoverBlob","summary":"Get a photo thumbnail.","description":"Returns the blob data of a photo thumbnail. Supports numeric row ID and photoId.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"string"}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Photos"]}},"/api/v1/photo-album/{id}":{"get":{"operationId":"PhotoAlbumController_getPhotoAlbum","summary":"Get a single photo album.","description":"Get a photo album.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"number"}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Photo Albums"]},"patch":{"operationId":"PhotoAlbumController_updatePhotoAlbum","summary":"Update a photo album.","description":"Updates a photo album.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"number"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdatePhotoAlbumBodyDto"}}}},"responses":{"200":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/PhotoAlbum"}}}}},"security":[{"Local User JWT":[]}],"tags":["Photo Albums"]},"delete":{"operationId":"PhotoAlbumController_deletePhotoAlbum","summary":"Delete a photo album.","description":"Deletes a photo album and the entry entities. Does not delete the original photos.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"number"}}],"responses":{"200":{"description":"Returns HTTP 200 if the deletion was successful.","content":{"application/json":{"schema":{}}}}},"security":[{"Local User JWT":[]}],"tags":["Photo Albums"]}},"/api/v1/photo-albums":{"get":{"operationId":"PhotoAlbumController_getPhotoAlbums","summary":"Get your photo albums.","description":"Get photo albums.","parameters":[{"name":"metadata","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"thumbnails","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"orderBy","required":false,"in":"query","schema":{"default":"createdAt","enum":["createdAt","modifiedAt"],"type":"string"}},{"name":"take","required":false,"in":"query","schema":{"default":12,"type":"number"}},{"name":"skip","required":false,"in":"query","schema":{"default":0,"type":"number"}}],"responses":{"200":{"description":"Returns an array where the first item is an array of query results, and the second item is the total number of photo albums."}},"security":[{"Local User JWT":[]}],"tags":["Photo Albums"]}},"/api/v1/photo-albums/count":{"get":{"operationId":"PhotoAlbumController_countPhotoAlbums","summary":"Count your photo albums.","description":"Endpoint optimized just for counting photo albums.","parameters":[],"responses":{"200":{"description":"Returns the total number of photo albums currently indexed in your database.","content":{"application/json":{"schema":{"example":24}}}}},"security":[{"Local User JWT":[]}],"tags":["Photo Albums"]}},"/api/v1/photo-album":{"post":{"operationId":"PhotoAlbumController_createPhotoAlbum","summary":"Create a new photo album.","description":"Creates a new photo album.","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreatePhotoAlbumDto"}}}},"responses":{"201":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/PhotoAlbum"}}}}},"security":[{"Local User JWT":[]}],"tags":["Photo Albums"]}},"/api/v1/photo-album/{id}/entries":{"get":{"operationId":"PhotoAlbumController_getPhotoAlbumEntries","summary":"Get photo album entries.","description":"Get entries from a photo album.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"number"}},{"name":"joinPhoto","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"joinPhotoAlbum","required":false,"in":"query","schema":{"default":false,"type":"boolean"}},{"name":"featured","required":false,"in":"query","schema":{"type":"boolean"}},{"name":"orderBy","required":false,"in":"query","schema":{"default":"createdAt","enum":["createdAt","modifiedAt"],"type":"string"}},{"name":"take","required":false,"in":"query","schema":{"default":12,"type":"number"}},{"name":"skip","required":false,"in":"query","schema":{"default":0,"type":"number"}}],"responses":{"200":{"description":"Returns an array of photo album entries.","content":{"application/json":{"schema":{}}}}},"security":[{"Local User JWT":[]}],"tags":["Photo Albums"]}},"/api/v1/thumbnails":{"delete":{"operationId":"ThumbnailController_deleteThumbnailFileCache","summary":"Delete all cached thumbnails files.","description":"Delete all cached thumbnail files on the disk.\n\nThis is a non-standard endpoint mainly used for development. The standard\nphilosophy for deleting thumbnails is to delete the entity that the\nthumbnails are derived from.\n\nThis does NOT delete any entities. This will leave you with broken file\npaths in your database.","parameters":[],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Thumbnails"]}},"/api/v1/job":{"post":{"operationId":"JobController_createJob","summary":"Create a new job.","description":"Create a new job and automatically runs it.","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateJobDto"}}}},"responses":{"201":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Job"}}}}},"security":[{"Local User JWT":[]}],"tags":["Jobs"]}},"/api/v1/jobs":{"get":{"operationId":"JobController_getJobs","summary":"Fetch server jobs.","description":"Query, sort, and filter server jobs.","parameters":[{"name":"take","required":false,"in":"query","schema":{"default":12,"type":"number"}},{"name":"skip","required":false,"in":"query","schema":{"default":0,"type":"number"}},{"name":"status","required":true,"in":"query","description":"draft, preparing, in_queue, running, paused, canceled, completed, errored","schema":{"type":"array","items":{"type":"string"}}},{"name":"type","required":true,"in":"query","description":"album_art_thumbnails, photo_variations, photo_thumbnails","schema":{"type":"array","items":{"type":"string"}}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Jobs"]}},"/api/v1/job/{id}":{"get":{"operationId":"JobController_getJob","summary":"Get a single job by ID.","description":"Get a single job by ID.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"number"}}],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Job"}}}}},"security":[{"Local User JWT":[]}],"tags":["Jobs"]},"patch":{"operationId":"JobController_updateJob","summary":"Update a job.","description":"If the job is currently in progress then the job runner will notice the\nchange before starting the next item in the job.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"number"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdateJobDto"}}}},"responses":{"200":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Job"}}}}},"security":[{"Local User JWT":[]}],"tags":["Jobs"]}},"/api/v1/job/{id}/tasks":{"get":{"operationId":"JobController_getJobTasks","summary":"Get a job's tasks.","description":"Get all the tasks of a job.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"number"}},{"name":"type","required":false,"in":"query","schema":{"enum":["create_album_artwork_thumbnail","create_photo_thumbnail","heic_to_jpeg"],"type":"string"}},{"name":"take","required":false,"in":"query","schema":{"default":12,"type":"number"}},{"name":"skip","required":false,"in":"query","schema":{"default":0,"type":"number"}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Jobs"]}},"/api/v1/jobs/types":{"get":{"operationId":"JobController_getJobTypes","summary":"Get all job types.","description":"Stops an active job.","parameters":[],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Jobs"]}},"/api/v1/library":{"post":{"operationId":"LibraryController_createLibrary","summary":"Create a new library.","description":"Create a library.","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateLibraryDto"}}}},"responses":{"201":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Library"}}}}},"security":[{"Local User JWT":[]}],"tags":["Libraries"]}},"/api/v1/libraries":{"get":{"operationId":"LibraryController_getLibraries","summary":"Get the current user's all libraries.","description":"Get all libraries.","parameters":[],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/Library"}}}}}},"security":[{"Local User JWT":[]}],"tags":["Libraries"]}},"/api/v1/library/{id}":{"get":{"operationId":"LibraryController_getLibrary","summary":"Get a library.","description":"Get a single library.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"number"}}],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Library"}}}}},"security":[{"Local User JWT":[]}],"tags":["Libraries"]},"patch":{"operationId":"LibraryController_updateLibrary","summary":"Update a library.","description":"Update a library.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"number"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdateLibraryBodyDto"}}}},"responses":{"200":{"description":"Returns HTTP 200 if the update was successful.","content":{"application/json":{"schema":{}}}}},"security":[{"Local User JWT":[]}],"tags":["Libraries"]},"delete":{"operationId":"LibraryController_deleteLibrary","summary":"Delete a library.","description":"Deletes a library.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"number"}}],"responses":{"200":{"description":"Returns HTTP 200 if the deletion was successful.","content":{"application/json":{"schema":{}}}}},"security":[{"Local User JWT":[]}],"tags":["Libraries"]}},"/api/v1/music/history":{"post":{"operationId":"MusicHistoryController_createPlaybackHistoryEntry","summary":"Save playback history.","description":"Create a history entry.","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateMusicHistoryEntryDto"}}}},"responses":{"201":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MusicHistory"}}}}},"security":[{"Local User JWT":[]}],"tags":["Music"]},"get":{"operationId":"MusicHistoryController_queryPlaybackHistory","summary":"Query playback history for the currently logged in user.","description":"Get the users playback history.","parameters":[{"name":"sort","required":false,"in":"query","schema":{"default":"createdAt","enum":["createdAt"],"type":"string"}},{"name":"take","required":false,"in":"query","schema":{"default":12,"type":"number"}},{"name":"skip","required":false,"in":"query","schema":{"default":0,"type":"number"}}],"responses":{"200":{"description":"Returns an array where the first item is the paginated set of results, and the second item is the total number of results for this query."}},"security":[{"Local User JWT":[]}],"tags":["Music"]}},"/api/v1/invitations/{id}":{"get":{"operationId":"InvitationController_getInvitation","summary":"Get data about an invitation.","description":"Get an invitation.","parameters":[{"name":"id","required":true,"in":"path","schema":{"type":"string"}}],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Invitation"}}}}},"security":[{"Local User JWT":[]}],"tags":["Invitations"]},"delete":{"operationId":"InvitationController_deleteInvitation","summary":"Delete a new invitation.","description":"Delete an invitation.","parameters":[],"responses":{"200":{"description":"","content":{"application/json":{"schema":{"type":"boolean"}}}}},"security":[{"Local User JWT":[]}],"tags":["Invitations"]}},"/api/v1/invitations":{"get":{"operationId":"InvitationController_queryInvitations","summary":"Query invitations.","description":"Query invitations","parameters":[{"name":"isExpired","required":false,"in":"query","schema":{"type":"boolean"}},{"name":"sort","required":false,"in":"query","schema":{"default":"createdAt","enum":["createdAt"],"type":"string"}},{"name":"take","required":false,"in":"query","schema":{"default":12,"type":"number"}},{"name":"skip","required":false,"in":"query","schema":{"default":0,"type":"number"}}],"responses":{"200":{"description":""}},"security":[{"Local User JWT":[]}],"tags":["Invitations"]},"post":{"operationId":"InvitationController_createInvitation","summary":"Create a new invitation.","description":"Create a new invitation.","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateInvitationDto"}}}},"responses":{"201":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Invitation"}}}}},"security":[{"Local User JWT":[]}],"tags":["Invitations"]}}},"info":{"title":"Cardinal Media Server API","description":"<p>This is the API specification for your <a href=\"https://cardinalapps.io/cardinal-media-server\" target=\"_blank\">Cardinal Media Server</a>.</p>\n      <p>For the responsible disclosure of a security vulnerability, please email <a href=\"mailto:hackers@cardinalapps.io\">hackers@cardinalapps.io</a>.</p>\n      <h2>Authorization</h2>\n      <p>There are two authorization tokens, and both are stored in your browser after you log in. You can enable developer mode in the app settings and copy the tokens from there.</p>\n      <ul>\n        <li><code>@cardinal/home_server_user_tolkien</code>: Token for an account in your Media Server.</li>\n        <li><code>@cardinal/cloud_user_tolkien</code>: Token for a Cardinal cloud account. Some endpoints require this in addition to the other token.</li>\n      </ul>\n      <p>Use the <code>home_server_user_tolkien</code> as the main authorization token in this API. Use the <code>cloud_user_tolkien</code> for endpoints that require the <code>CardinalTolkien</code> parameter or header.</p>\n      <h2>Deleting Things</h2>\n      <p>None of the deletion endpoints in this API will delete your source media files. The only files that Cardinal will delete are the ones from its own cache. Rest assured that you can delete things from your database and your original files will stay safe.</p>\n    ","version":"","contact":{}},"tags":[{"name":"General","description":""},{"name":"Events","description":""},{"name":"Authentication","description":""},{"name":"Settings","description":""},{"name":"User","description":""},{"name":"Indexing","description":""},{"name":"Jobs","description":""},{"name":"Libraries","description":""},{"name":"Music","description":""},{"name":"Photos","description":""},{"name":"Photo Albums","description":""}],"servers":[],"components":{"securitySchemes":{"Local User JWT":{"scheme":"Bearer","bearerFormat":"JWT","name":"Authorization","description":"Enter the JWT generated by your Cardinal Media Server for a local user. Do not prefix with \"Bearer\".","type":"http","in":"Header"}},"schemas":{"ServerSetupDto":{"type":"object","properties":{"theme":{"type":"string"},"serverName":{"type":"string"},"sendAnonymousUsageData":{"type":"boolean"},"ssoToken":{"type":"string"}}},"ServerResetDto":{"type":"object","properties":{"type":{"type":"string","enum":["media","factory"]},"validationString":{"type":"string","description":"A string of text must be entered to prevent accidentially triggering this endpoint.","enum":["Deindex media","Factory reset"]}},"required":["type","validationString"]},"LoginDetails":{"type":"object","properties":{"userId":{"type":"string"},"cardinalJWT":{"type":"string"}}},"LoginResponse":{"type":"object","properties":{"JWT":{"type":"string"},"user":{"type":"object"},"cloudJWT":{"type":"string","description":"The security implications of returning a cloud JWT to the client are\nunderstood and accounted for."},"cloudUser":{"type":"object"}},"required":["JWT","user"]},"GetAppSettingsResponse":{"type":"object","properties":{"settings":{"type":"object","default":{}}},"required":["settings"]},"UpsertSettings":{"type":"object","properties":{"app":{"type":"string","description":"Leave blank to have the settings update apply to all apps","enum":["admin","music","photos","cinema"]},"settings":{"type":"object","default":{}}},"required":["settings"]},"UpsertSettingsResponse":{"type":"object","properties":{"updated":{"type":"object","default":{}}}},"GetUserResponse":{"type":"object","properties":{"cardinalUser":{"type":"object"},"localUser":{"type":"object"}},"required":["localUser"]},"User":{"type":"object","properties":{"userId":{"type":"string"},"cardinalId":{"type":"string"},"cachedCloudUser":{"type":"object","properties":{"subscription":{"required":true,"enum":["free","early_adopter"],"type":"string"}}},"cachedCloudUserAt":{"format":"date-time","type":"string"},"enabled":{"type":"boolean"},"ssoToken":{"type":"string"},"role":{"type":"string","deprecated":true},"designation":{"type":"string"},"activityStatus":{"type":"string"},"activityStatusUpdatedAt":{"format":"date-time","type":"string"},"roles":{"type":"array","items":{"$ref":"#/components/schemas/RoleAssignment"}},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["userId","cachedCloudUser","role","roles","id","createdAt","updatedAt","deletedAt"]},"RoleAssignment":{"type":"object","properties":{"id":{"type":"number"},"user":{"$ref":"#/components/schemas/User"},"role":{"type":"string"}},"required":["id","user","role"]},"CreateUser":{"type":"object","properties":{"cardinalJWT":{"type":"string"},"role":{"type":"object"}}},"UpdateUserDto":{"type":"object","properties":{"enabled":{"type":"boolean"}}},"AssignRolesDto":{"type":"object","properties":{"userIds":{"default":[],"type":"array","items":{"type":"string"}}},"required":["userIds"]},"StateChangeActionDto":{"type":"object","properties":{"action":{"type":"object"}},"required":["action"]},"CreateRunDto":{"type":"object","properties":{"indexMusic":{"type":"boolean"},"indexPhotos":{"type":"boolean"},"indexMovies":{"type":"boolean"},"indexTV":{"type":"boolean"}},"required":["indexMusic","indexPhotos","indexMovies","indexTV"]},"Run":{"type":"object","properties":{"runId":{"type":"string"},"file":{"type":"array","items":{"$ref":"#/components/schemas/File"}},"status":{"type":"string"},"photosIndexed":{"type":"object"},"musicIndexed":{"type":"object"},"moviesIndexed":{"type":"object"},"tvIndexed":{"type":"object"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["runId","status","id","createdAt","updatedAt","deletedAt"]},"MusicGenre":{"type":"object","properties":{"releases":{"type":"array","items":{"$ref":"#/components/schemas/MusicRelease"}},"musicGenreId":{"type":"string"},"name":{"type":"string"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["musicGenreId","id","createdAt","updatedAt","deletedAt"]},"MusicReleaseMetadata":{"type":"object","properties":{"release":{"$ref":"#/components/schemas/MusicRelease"},"metadataType":{"type":"object"},"metadataFormat":{"type":"object"},"metaKey":{"type":"string"},"metaValue":{"type":"string"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["release","metaKey","id","createdAt","updatedAt","deletedAt"]},"MusicReleaseThumbnail":{"type":"object","properties":{"thumbnailId":{"type":"string"},"absolutePath":{"type":"string","nullable":true},"relativeSrc":{"type":"string","nullable":true},"size":{"type":"string"},"format":{"type":"string"},"width":{"type":"number"},"height":{"type":"number"},"bytes":{"type":"number"},"release":{"$ref":"#/components/schemas/MusicRelease"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["thumbnailId","absolutePath","relativeSrc","size","format","width","height","bytes","release","id","createdAt","updatedAt","deletedAt"]},"MusicRelease":{"type":"object","properties":{"tracks":{"type":"array","items":{"$ref":"#/components/schemas/MusicTrack"}},"artist":{"description":"This is the primary artist.\n\nSee: https://github.com/borewit/music-metadata/blob/HEAD/doc/common_metadata.md","allOf":[{"$ref":"#/components/schemas/MusicArtist"}]},"artists":{"description":"This is the list of all artists that contributed to the album. It includes\nthe primary artist.\n\nSee: https://github.com/borewit/music-metadata/blob/HEAD/doc/common_metadata.md","type":"array","items":{"$ref":"#/components/schemas/MusicArtist"}},"genres":{"type":"array","items":{"$ref":"#/components/schemas/MusicGenre"}},"musicReleaseId":{"type":"string"},"title":{"type":"string"},"sortTitle":{"type":"string"},"metadata":{"type":"array","items":{"$ref":"#/components/schemas/MusicReleaseMetadata"}},"thumbnails":{"type":"array","items":{"$ref":"#/components/schemas/MusicReleaseThumbnail"}},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["musicReleaseId","id","createdAt","updatedAt","deletedAt"]},"MusicArtistMetadata":{"type":"object","properties":{"musicTrack":{"$ref":"#/components/schemas/MusicArtist"},"metadataType":{"type":"object"},"metadataFormat":{"type":"object"},"metaKey":{"type":"string"},"metaValue":{"type":"string"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["musicTrack","metaKey","id","createdAt","updatedAt","deletedAt"]},"MusicArtist":{"type":"object","properties":{"tracks":{"type":"array","items":{"$ref":"#/components/schemas/MusicTrack"}},"releases":{"type":"array","items":{"$ref":"#/components/schemas/MusicRelease"}},"musicArtistId":{"type":"string"},"name":{"type":"string"},"sortName":{"type":"string"},"metadata":{"type":"array","items":{"$ref":"#/components/schemas/MusicArtistMetadata"}},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["musicArtistId","id","createdAt","updatedAt","deletedAt"]},"MusicTrackMetadata":{"type":"object","properties":{"track":{"$ref":"#/components/schemas/MusicTrack"},"metadataType":{"type":"object"},"metadataFormat":{"type":"object"},"metaKey":{"type":"string"},"metaValue":{"type":"string"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["track","metaKey","id","createdAt","updatedAt","deletedAt"]},"MusicHistory":{"type":"object","properties":{"id":{"type":"number"},"playbackEntryId":{"type":"string"},"progress":{"type":"number"},"track":{"$ref":"#/components/schemas/MusicTrack"},"user":{"$ref":"#/components/schemas/User"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["id","playbackEntryId","progress","track","user","createdAt","updatedAt","deletedAt"]},"MusicTrack":{"type":"object","properties":{"file":{"$ref":"#/components/schemas/File"},"artists":{"type":"array","items":{"$ref":"#/components/schemas/MusicArtist"}},"release":{"$ref":"#/components/schemas/MusicRelease"},"musicTrackId":{"type":"string"},"title":{"type":"string"},"sortTitle":{"type":"string"},"trackNumber":{"type":"number"},"discNumber":{"type":"number"},"duration":{"type":"number"},"bitrate":{"type":"number"},"metadata":{"type":"array","items":{"$ref":"#/components/schemas/MusicTrackMetadata"}},"history":{"type":"array","items":{"$ref":"#/components/schemas/MusicHistory"}},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["file","artists","release","musicTrackId","id","createdAt","updatedAt","deletedAt"]},"PhotoMetadata":{"type":"object","properties":{"photo":{"$ref":"#/components/schemas/Photo"},"metadataType":{"type":"string"},"metadataFormat":{"type":"string"},"metaKey":{"type":"string"},"metaValue":{"type":"string"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["photo","metaKey","id","createdAt","updatedAt","deletedAt"]},"PhotoThumbnail":{"type":"object","properties":{"thumbnailId":{"type":"string"},"absolutePath":{"type":"string","nullable":true},"relativeSrc":{"type":"string","nullable":true},"size":{"type":"string"},"format":{"type":"string"},"width":{"type":"number"},"height":{"type":"number"},"bytes":{"type":"number"},"photo":{"$ref":"#/components/schemas/Photo"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["thumbnailId","absolutePath","relativeSrc","size","format","width","height","bytes","photo","id","createdAt","updatedAt","deletedAt"]},"PhotoVariation":{"type":"object","properties":{"variationId":{"type":"string"},"absolutePath":{"type":"string","nullable":true},"relativeSrc":{"type":"string","nullable":true},"format":{"type":"string"},"bytes":{"type":"number"},"photo":{"$ref":"#/components/schemas/Photo"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["variationId","absolutePath","relativeSrc","format","bytes","photo","id","createdAt","updatedAt","deletedAt"]},"PhotoAlbumMetadata":{"type":"object","properties":{"photoAlbum":{"$ref":"#/components/schemas/PhotoAlbum"},"metaKey":{"type":"string"},"metaValue":{"type":"string"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["photoAlbum","metaKey","id","createdAt","updatedAt","deletedAt"]},"PhotoAlbum":{"type":"object","properties":{"user":{"$ref":"#/components/schemas/User"},"photoAlbumId":{"type":"string"},"name":{"type":"string"},"entries":{"type":"array","items":{"$ref":"#/components/schemas/PhotoAlbumEntry"}},"metadata":{"type":"array","items":{"$ref":"#/components/schemas/PhotoAlbumMetadata"}},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["photoAlbumId","name","entries","metadata","id","createdAt","updatedAt","deletedAt"]},"PhotoAlbumEntry":{"type":"object","properties":{"photoAlbumEntryId":{"type":"string"},"photo":{"$ref":"#/components/schemas/Photo"},"photoAlbum":{"$ref":"#/components/schemas/PhotoAlbum"},"featured":{"type":"boolean"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["photoAlbumEntryId","photo","photoAlbum","featured","id","createdAt","updatedAt","deletedAt"]},"Photo":{"type":"object","properties":{"photoId":{"type":"string"},"file":{"$ref":"#/components/schemas/File"},"metadata":{"type":"array","items":{"$ref":"#/components/schemas/PhotoMetadata"}},"thumbnail":{"type":"array","items":{"$ref":"#/components/schemas/PhotoThumbnail"}},"variations":{"type":"array","items":{"$ref":"#/components/schemas/PhotoVariation"}},"photoAlbumEntries":{"type":"array","items":{"$ref":"#/components/schemas/PhotoAlbumEntry"}},"timestamp":{"type":"number"},"takenAt":{"format":"date-time","type":"string"},"takenOnDay":{"type":"string"},"modifiedAt":{"format":"date-time","type":"string"},"width":{"type":"number"},"height":{"type":"number"},"orientation":{"type":"string"},"deviceMake":{"type":"string"},"deviceModel":{"type":"string"},"gpsLat":{"type":"number"},"gpsLng":{"type":"number"},"gpsLatRef":{"type":"string"},"gpsLngRef":{"type":"string"},"gpsAltitude":{"type":"string"},"gpsTime":{"type":"string"},"gpsDate":{"type":"string"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["photoId","file","metadata","thumbnail","variations","photoAlbumEntries","timestamp","takenAt","takenOnDay","modifiedAt","width","height","orientation","deviceMake","deviceModel","gpsLat","gpsLng","gpsLatRef","gpsLngRef","gpsAltitude","gpsTime","gpsDate","id","createdAt","updatedAt","deletedAt"]},"Job":{"type":"object","properties":{"jobId":{"type":"string"},"user":{"$ref":"#/components/schemas/User"},"run":{"$ref":"#/components/schemas/Run"},"type":{"enum":["album_art_thumbnails","photo_variations","photo_thumbnails"],"type":"string"},"status":{"enum":["draft","preparing","in_queue","running","paused","canceled","completed","errored"],"type":"string"},"parameters":{"type":"object"},"tasks":{"type":"array","items":{"$ref":"#/components/schemas/JobTask"}},"completedTasks":{"type":"number"},"remainingTasks":{"type":"number"},"totalTasks":{"type":"number"},"completedAt":{"format":"date-time","type":"string"},"errorMessage":{"type":"string"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["jobId","run","type","status","completedTasks","remainingTasks","totalTasks","completedAt","errorMessage","id","createdAt","updatedAt","deletedAt"]},"JobTask":{"type":"object","properties":{"jobTaskId":{"type":"string"},"job":{"$ref":"#/components/schemas/Job"},"file":{"$ref":"#/components/schemas/File"},"type":{"type":"string","enum":["create_album_artwork_thumbnail","create_photo_thumbnail","heic_to_jpeg"]},"target":{"type":"string","description":"The target is the thing that the job task has to do its work on, and it\nshould be a string that refers to anything (ID, URL, slug)."},"status":{"type":"string","enum":["draft","in_queue","running","paused","canceled","completed","errored"]},"completedAt":{"format":"date-time","type":"string"},"errorMessage":{"type":"string"},"results":{"type":"object"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["jobTaskId","type","target","status","completedAt","errorMessage","id","createdAt","updatedAt","deletedAt"]},"File":{"type":"object","properties":{"user":{"$ref":"#/components/schemas/User"},"run":{"$ref":"#/components/schemas/Run"},"musicTrack":{"type":"array","items":{"$ref":"#/components/schemas/MusicTrack"}},"photo":{"$ref":"#/components/schemas/Photo"},"fileId":{"type":"string"},"jobTasks":{"type":"array","items":{"$ref":"#/components/schemas/JobTask"}},"absolutePath":{"type":"string"},"relativePath":{"type":"string"},"mimeType":{"type":"string"},"extension":{"type":"string"},"app":{"type":"string"},"mediaType":{"type":"string"},"size":{"type":"number"},"lastSeen":{"format":"date-time","type":"string"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["user","run","fileId","jobTasks","absolutePath","relativePath","extension","app","mediaType","size","lastSeen","id","createdAt","updatedAt","deletedAt"]},"UpdatePhotoBodyDto":{"type":"object","properties":{"photoAlbums":{"type":"array","items":{"type":"number"}}},"required":["photoAlbums"]},"CreatePhotoAlbumDto":{"type":"object","properties":{"name":{"type":"string"}},"required":["name"]},"UpdatePhotoAlbumBodyDto":{"type":"object","properties":{"name":{"type":"string"}},"required":["name"]},"CreateJobDto":{"type":"object","properties":{"type":{"type":"string","enum":["album_art_thumbnails","photo_variations","photo_thumbnails"]}},"required":["type"]},"UpdateJobDto":{"type":"object","properties":{"status":{"type":"string","enum":["draft","preparing","in_queue","running","paused","canceled","completed","errored"]},"completedAt":{"format":"date-time","type":"string"}}},"CreateLibraryDto":{"type":"object","properties":{"name":{"type":"string"},"paths":{"type":"array","items":{"type":"string"}}},"required":["name","paths"]},"Library":{"type":"object","properties":{"id":{"type":"number"},"libraryId":{"type":"string"},"name":{"type":"string"},"paths":{"type":"array","items":{"type":"string"}},"user":{"$ref":"#/components/schemas/User"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["id","libraryId","name","paths","user","createdAt","updatedAt","deletedAt"]},"UpdateLibraryBodyDto":{"type":"object","properties":{"name":{"type":"string"},"paths":{"type":"array","items":{"type":"string"}}}},"CreateMusicHistoryEntryDto":{"type":"object","properties":{"seconds":{"type":"number"},"trackId":{"type":"string"}},"required":["seconds","trackId"]},"Invitation":{"type":"object","properties":{"invitationId":{"type":"string"},"expiresAt":{"format":"date-time","type":"string"},"createdBy":{"$ref":"#/components/schemas/User"},"invitee":{"type":"string"},"cloudLink":{"type":"string"},"userFriendlyCode":{"type":"string"},"type":{"type":"object"},"id":{"type":"number"},"createdAt":{"format":"date-time","type":"string"},"updatedAt":{"format":"date-time","type":"string"},"deletedAt":{"format":"date-time","type":"string"}},"required":["invitationId","createdBy","cloudLink","type","id","createdAt","updatedAt","deletedAt"]},"CreateInvitationDto":{"type":"object","properties":{}}}}}
