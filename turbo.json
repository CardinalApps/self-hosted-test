{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": ["TZ", "npm_package_version", "CARDINAL_POSTGRES", "APP_ENCRYPTION_KEY", "MONGODB_URI", "MONGODB_DB_NAME", "NODE_ENV", "LOG_LEVEL"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [],
      "cache": false
    },
    "typecheck": {
      "dependsOn": [],
      "cache": false
    },
    "test:unit": {
      "dependsOn": []
    },
    "test:integration": {
      "dependsOn": []
    },
    "test:e2e": {
      "dependsOn": []
    },
    "test:e2e:ui": {
      "cache": false,
      "persistent": true
    },
    "test:e2e:install": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["build/**", "dist/**", ".next/**", "!.next/cache/**"]
    },
    "serve": {
      "dependsOn": ["^serve"]
    },
    "@cardinalapps/access-control#dev": {
      "dependsOn": [],
      "cache": false,
      "persistent": true
    },
    "@cardinalapps/topology#dev": {
      "dependsOn": [],
      "cache": false,
      "persistent": true
    },
    "@cardinalapps/app-settings#dev": {
      "dependsOn": [],
      "cache": false,
      "persistent": true
    },
    "@cardinalapps/products#dev": {
      "dependsOn": [],
      "cache": false,
      "persistent": true
    },
    "@cardinalapps/cloud-entry#dev": {
      "dependsOn": [
        "@cardinalapps/access-control#build",
        "@cardinalapps/topology#build"
      ],
      "cache": false,
      "persistent": true
    },
    "@cardinalapps/feedback-server#dev": {
      "dependsOn": [
        "@cardinalapps/topology#build"
      ],
      "cache": false
    },
    "@cardinalapps/auth-server#dev": {
      "dependsOn": [
        "@cardinalapps/access-control#build",
        "@cardinalapps/products#build"
      ],
      "cache": false
    },
    "@cardinalapps/media-server#dev": {
      "dependsOn": [
        "@cardinalapps/access-control#build",
        "@cardinalapps/app-settings#build",
        "@cardinalapps/products#build",
        "@cardinalapps/topology#build"
      ],
      "cache": false
    },
    "@cardinalapps/remote-access-server#dev": {
      "dependsOn": [
        "@cardinalapps/remote-access#build"
      ],
      "cache": false
    }
  }
}
