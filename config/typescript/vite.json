{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "target": "ES2020",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@cardinalapps/access-control/*": ["../../libraries/access-control/*"],
      "@cardinalapps/app-settings/*": ["../../libraries/app-settings/*"],
      "@cardinalapps/products/*": ["../../libraries/products/*"],
      "@cardinalapps/types/*": ["../../libraries/types/*"],
      "@cardinalapps/ui/*": ["../../libraries/ui/*"]
    }
  }
}
